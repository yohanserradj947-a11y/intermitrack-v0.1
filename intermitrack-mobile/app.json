{
  "expo": {
    "name": "Intermitrack",
    "slug": "intermitrack-mobile",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "intermitrackmobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/6affbaa2-75e9-46bd-88e8-1b73f675cc70"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fr.intermitrack.app",
      "appleTeamId": "8RHAK6PW39",
      "entitlements": {
        "com.apple.security.application-groups": ["group.fr.intermitrack.app"]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "fr.intermitrack.app",
      "adaptiveIcon": {
        "backgroundColor": "#123440",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-calendar",
        {
          "calendarPermission": "Intermitrack accède à ton calendrier pour importer tes missions et te faire gagner du temps."
        }
      ],
      "@bacons/apple-targets",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "Hours",
              "label": "Intermitrack — Heures / 507 h",
              "description": "Ta progression vers les droits France Travail.",
              "minWidth": "140dp",
              "minHeight": "140dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "none",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "Next",
              "label": "Intermitrack — Prochaine mission",
              "description": "Ta prochaine mission d'un coup d'oeil.",
              "minWidth": "140dp",
              "minHeight": "140dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "none",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "CalendarAgenda",
              "label": "Intermitrack — Calendrier (agenda)",
              "description": "Mini-calendrier + prochaines missions.",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "CalendarMonth",
              "label": "Intermitrack — Calendrier (mois)",
              "description": "Le mois complet, colore par prod, + a venir.",
              "minWidth": "250dp",
              "minHeight": "250dp",
              "targetCellWidth": 4,
              "targetCellHeight": 4,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6affbaa2-75e9-46bd-88e8-1b73f675cc70"
      }
    }
  }
}
